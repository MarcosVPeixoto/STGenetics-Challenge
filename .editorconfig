[*.cs]

# CS8618: O campo não anulável precisa conter um valor não nulo ao sair do construtor. Considere declará-lo como anulável.
dotnet_diagnostic.CS8618.severity = none

# Default severity for all analyzer diagnostics
dotnet_analyzer_diagnostic.severity = none

# CS8603: Possible null reference return.
dotnet_diagnostic.CS8603.severity = none

# SYSLIB0023: Type or member is obsolete
dotnet_diagnostic.SYSLIB0023.severity = none

# SYSLIB0041: Type or member is obsolete
dotnet_diagnostic.SYSLIB0041.severity = none
